# Solana RPC URL (gunakan Helius/QuickNode untuk rate limit lebih tinggi)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (gratis di https://helius.dev) - untuk parsed transaction
HELIUS_API_KEY=your_helius_api_key_here

# Wallet address yang ingin di-track
WALLET_ADDRESS=your_target_wallet_address_here

# Label untuk wallet (opsional, untuk display di notifikasi)
WALLET_LABEL=Smart Wallet

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (dari @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Polling interval dalam detik
POLL_INTERVAL=10
